---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const activeProjects = (await getCollection('projects', ({ data }) => data.status === 'active'))
  .slice(0, 4);

const categoryColors: Record<string, string> = {
  science:  'text-emerald-700 bg-emerald-50 border-emerald-200',
  startup:  'text-blue-700 bg-blue-50 border-blue-200',
  personal: 'text-amber-700 bg-amber-50 border-amber-200',
};
---
<BaseLayout title="David Rourap" darkNav={true}>

  <!-- ═══════════════════════════════════════════
       HERO — dark, editorial, full-height
  ═══════════════════════════════════════════ -->
  <section class="relative min-h-screen bg-[#090a0e] flex flex-col justify-end overflow-hidden">

    <!-- Radial depth glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_15%_70%,_#0d1428_0%,_transparent_55%)] pointer-events-none"></div>

    <!-- Subtle grid -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.025)_1px,transparent_1px)] bg-[size:72px_72px] pointer-events-none"></div>

    <!-- Content -->
    <div class="relative max-w-6xl mx-auto px-8 w-full pb-16 pt-28">

      <!-- Role labels -->
      <div class="flex flex-wrap gap-6 mb-10 animate-in" style="animation-delay:0.1s">
        <span class="font-mono text-[11px] text-[#4d607a] tracking-[0.25em] uppercase">01 — Scientist</span>
        <span class="font-mono text-[11px] text-[#4d607a] tracking-[0.25em] uppercase">02 — CEO, inseit.ch</span>
        <span class="font-mono text-[11px] text-[#2d3548] tracking-[0.25em] uppercase">Switzerland</span>
      </div>

      <!-- Name — the centrepiece -->
      <h1 class="font-display font-semibold leading-[0.88] tracking-[-0.02em] text-[#f0ece3] mb-10"
          style="font-size: clamp(4.5rem, 13vw, 11rem)">
        <span class="block animate-in" style="animation-delay:0.2s">David</span>
        <span class="block animate-in" style="animation-delay:0.32s; font-size: clamp(5rem, 15vw, 13rem)">Rourap</span>
      </h1>

      <!-- Divider -->
      <div class="w-full h-px bg-[#1e2130] mb-10 animate-line" style="animation-delay:0.5s"></div>

      <!-- Bio + CTAs -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 animate-in" style="animation-delay:0.6s">
        <p class="font-serif text-[1.1rem] text-[#7a7d8a] leading-relaxed max-w-sm">
          Building at the intersection of science and entrepreneurship.
          Founder of <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer"
            class="text-[#9aa8c0] hover:text-[#f0ece3] transition-colors underline underline-offset-2">inseit.ch</a>.
        </p>
        <div class="flex gap-3 shrink-0">
          <a href="/blog"
             class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#f0ece3] border border-[#3a3d4a] px-6 py-3 hover:bg-[#f0ece3] hover:text-[#090a0e] transition-all duration-200">
            Writing →
          </a>
          <a href="/projects"
             class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#8a8d9a] border border-[#2a2d3a] px-6 py-3 hover:border-[#3a3d4a] hover:text-[#f0ece3] transition-all duration-200">
            Work
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 right-8 animate-in" style="animation-delay:1s">
      <span class="font-mono text-[10px] text-[#2a2d3a] tracking-[0.3em] uppercase">Scroll ↓</span>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       CONTENT — warm cream sections
  ═══════════════════════════════════════════ -->
  <div class="bg-[#f4efe5]">

    <!-- Recent writing -->
    {recentPosts.length > 0 && (
      <section class="max-w-6xl mx-auto px-8 pt-20 pb-10">
        <div class="flex items-center gap-5 mb-12">
          <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase shrink-0">Recent writing</span>
          <div class="flex-1 h-px bg-[#ddd8ce]"></div>
          <a href="/blog" class="font-mono text-[10px] text-[#2355b0] tracking-[0.15em] uppercase hover:underline shrink-0">All →</a>
        </div>

        <div class="space-y-px border border-[#ddd8ce]">
          {recentPosts.map((post, i) => {
            const slug = post.id.replace(/\.mdx?$/, '');
            return (
              <a href={`/blog/${slug}`} class="group block">
                <article class="flex items-center gap-6 px-6 py-5 bg-[#faf7f2] hover:bg-white transition-colors border-b border-[#ddd8ce] last:border-b-0">
                  <span class="font-mono text-[10px] text-[#ccc8c0] w-5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-serif text-[1.05rem] font-semibold text-[#0f0e0c] group-hover:text-[#2355b0] transition-colors leading-snug">
                      {post.data.title}
                    </h3>
                    <p class="font-serif text-sm text-[#7a7570] mt-0.5 line-clamp-1">{post.data.description}</p>
                  </div>
                  <div class="shrink-0 flex items-center gap-4">
                    <span class={`font-mono text-[10px] tracking-[0.1em] uppercase px-2 py-0.5 border ${categoryColors[post.data.category]}`}>
                      {post.data.category}
                    </span>
                    <span class="font-mono text-[10px] text-[#aaa59f] hidden sm:block">
                      {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Active projects -->
    {activeProjects.length > 0 && (
      <section class="max-w-6xl mx-auto px-8 pt-10 pb-20">
        <div class="flex items-center gap-5 mb-12">
          <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase shrink-0">Active work</span>
          <div class="flex-1 h-px bg-[#ddd8ce]"></div>
          <a href="/projects" class="font-mono text-[10px] text-[#2355b0] tracking-[0.15em] uppercase hover:underline shrink-0">All →</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {activeProjects.map(project => (
            <a
              href={project.data.link ?? '/projects'}
              target={project.data.link ? '_blank' : '_self'}
              rel="noopener noreferrer"
              class="group block"
            >
              <article class="bg-[#faf7f2] border border-[#ddd8ce] p-6 h-full hover:bg-white hover:border-[#c0b8ac] transition-all">
                <div class="flex items-center justify-between mb-3">
                  <span class={`font-mono text-[10px] tracking-[0.15em] uppercase px-2 py-0.5 border
                    ${project.data.type === 'startup' ? 'text-blue-700 bg-blue-50 border-blue-200' : 'text-emerald-700 bg-emerald-50 border-emerald-200'}`}>
                    {project.data.type}
                  </span>
                  {project.data.year && (
                    <span class="font-mono text-[10px] text-[#aaa59f]">{project.data.year}</span>
                  )}
                </div>
                <h3 class="font-display text-[1.35rem] font-semibold text-[#0f0e0c] group-hover:text-[#2355b0] transition-colors leading-tight mb-2">
                  {project.data.title}
                  {project.data.link && <span class="text-[#aaa59f] ml-1 text-base">↗</span>}
                </h3>
                <p class="font-serif text-sm text-[#7a7570] leading-relaxed">{project.data.description}</p>
              </article>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

</BaseLayout>
