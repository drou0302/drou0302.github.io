---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const [aboutEntry] = await getCollection('about');
const { intro, network_nodes } = aboutEntry.data;

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const statusOrder: Record<string, number> = { active: 0, paused: 1, completed: 2 };
const allProjects = (await getCollection('projects'))
  .sort((a, b) =>
    (statusOrder[a.data.status] ?? 9) - (statusOrder[b.data.status] ?? 9) ||
    (b.data.year ?? 0) - (a.data.year ?? 0)
  );

const categoryColors: Record<string, string> = {
  science:  'text-[#D2E59E] border-[#6D5959]',
  startup:  'text-[#9FA0C3] border-[#6D5959]',
  personal: 'text-[#FE9000] border-[#6D5959]',
};

const projectTypeColors: Record<string, string> = {
  research: 'text-[#D2E59E] border-[#6D5959]',
  startup:  'text-[#9FA0C3] border-[#6D5959]',
  personal: 'text-[#FE9000] border-[#6D5959]',
  hobby:     'text-[#FE9000] border-[#6D5959]',
  education: 'text-[#9FA0C3] border-[#6D5959]',
};

const navLinks = [
  ['01', 'About',    '/about'],
  ['02', 'Research', '/research'],
  ['03', 'Blog',     '/blog'],
  ['04', 'Projects', '/projects'],
  ['05', 'CV',       '/cv'],
] as const;
---

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .fu   { opacity: 0; animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .fu-1 { animation-delay: 0.05s; }
  .fu-2 { animation-delay: 0.2s;  }
  .fu-3 { animation-delay: 0.38s; }
  .fu-4 { animation-delay: 0.56s; }
  .fu-5 { animation-delay: 0.74s; }
  .fi   { opacity: 0; animation: fadeIn 1.8s ease forwards 0.1s; }
</style>

<BaseLayout title="David Roura Padrosa" darkNav={true}>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="relative h-screen bg-[#000500] overflow-hidden">

    <div class="absolute inset-0 grid grid-cols-1 lg:grid-cols-[55%_45%]">

      <!-- Text column -->
      <div class="relative flex flex-col justify-center px-10 md:px-16 lg:px-20 pt-28 pb-12">

        <!-- Coordinate annotation -->
        <div class="fu fu-1 absolute top-[4.5rem] left-10 md:left-16 lg:left-20 flex items-center gap-3">
          <div class="h-px w-6 bg-[#6D5959]"></div>
          <span class="font-mono text-[9px] text-[#6D5959] tracking-[0.3em] uppercase">48°8'N 11°34'E — Munich</span>
        </div>

        <!-- Name -->
        <h1 class="fu fu-2 font-display font-semibold text-[#D2E59E] tracking-[-0.03em]"
            style="font-size:clamp(3.4rem,8.5vw,8.5rem);line-height:0.82;">
          David<br/>Roura<br/>Padrosa
        </h1>

        <!-- Orange rule + role -->
        <div class="fu fu-3 flex items-center gap-5 mt-8 mb-7">
          <div class="h-px w-12 bg-[#FE9000] flex-shrink-0"></div>
          <span class="font-mono text-[10px] text-[#9FA0C3] tracking-[0.28em] uppercase">Biochemist · Founder</span>
        </div>

        <!-- Intro -->
        <p class="fu fu-4 font-serif text-[1.05rem] text-[#9FA0C3] leading-relaxed max-w-[400px] mb-10">
          {intro}
        </p>

        <!-- Numbered nav -->
        <nav class="fu fu-5 flex flex-wrap gap-x-7 gap-y-3">
          {navLinks.map(([n, label, href]) => (
            <a href={href}
               class="group flex items-baseline gap-1.5 font-mono text-[10px] tracking-[0.18em] uppercase text-[#9FA0C3] hover:text-[#FE9000] transition-colors duration-200">
              <span class="text-[8px] text-[#6D5959] group-hover:text-[#FE9000] transition-colors">{n}</span>
              {label}
            </a>
          ))}
        </nav>

        <!-- Scroll indicator -->
        <div class="fu fu-5 absolute bottom-8 left-10 md:left-16 lg:left-20">
          <span class="font-mono text-[9px] text-[#6D5959] tracking-[0.3em] uppercase">Scroll ↓</span>
        </div>
      </div>

      <!-- Particle network column (desktop) -->
      <div class="relative hidden lg:block fi">
        <!-- Edge blends -->
        <div class="absolute inset-y-0 left-0 w-40 z-10 pointer-events-none"
             style="background:linear-gradient(to right,#000500,transparent);"></div>
        <div class="absolute inset-x-0 top-0 h-16 z-10 pointer-events-none"
             style="background:linear-gradient(to bottom,#000500,transparent);"></div>
        <div class="absolute inset-x-0 bottom-0 h-24 z-10 pointer-events-none"
             style="background:linear-gradient(to top,#000500,transparent);"></div>

        <canvas id="particle-canvas" class="absolute inset-0 w-full h-full"></canvas>

        <!-- Vertical annotation -->
        <div class="absolute bottom-10 right-7 z-20">
          <span class="font-mono text-[9px] text-[#6D5959]"
                style="writing-mode:vertical-rl;letter-spacing:0.28em;text-transform:uppercase;">
            Biochemistry · Networks
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Recent writing ───────────────────────────────────── -->
  {recentPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-10 md:px-16 pt-24 pb-12">

      <div class="flex items-center gap-4 mb-16">
        <span class="font-mono text-[9px] text-[#6D5959] tracking-[0.3em] uppercase shrink-0">Recent writing</span>
        <div class="flex-1 h-px bg-[#6D5959]"></div>
        <a href="/blog" class="font-mono text-[9px] text-[#FE9000] tracking-[0.2em] uppercase hover:underline shrink-0">All →</a>
      </div>

      <div>
        {recentPosts.map((post, i) => {
          const slug = post.id.replace(/\.mdx?$/, '');
          return (
            <a href={`/blog/${slug}`} class="group block border-t border-[#6D5959] py-8 hover:border-[#FE9000] transition-colors last:border-b last:border-b-[#6D5959]">
              <div class="flex items-start gap-6 md:gap-10">
                <span class="font-mono text-[10px] text-[#6D5959] mt-1 shrink-0 group-hover:text-[#FE9000] transition-colors">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <h3 class="font-display text-[1.5rem] font-semibold text-[#D2E59E] group-hover:text-[#FE9000] transition-colors leading-tight mb-2">
                    {post.data.title}
                  </h3>
                  <p class="font-serif text-sm text-[#9FA0C3] leading-relaxed line-clamp-2 mb-4">{post.data.description}</p>
                  <div class="flex items-center gap-4">
                    <span class="font-mono text-[9px] text-[#6D5959]">
                      {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                    <span class={`font-mono text-[9px] tracking-[0.1em] uppercase px-2 py-0.5 border ${categoryColors[post.data.category]}`}>
                      {post.data.category}
                    </span>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- ── Projects ────────────────────────────────────────────── -->
  {allProjects.length > 0 && (
    <section class="max-w-5xl mx-auto px-10 md:px-16 pt-12 pb-24">

      <div class="flex items-center gap-4 mb-16">
        <span class="font-mono text-[9px] text-[#6D5959] tracking-[0.3em] uppercase shrink-0">Projects</span>
        <div class="flex-1 h-px bg-[#6D5959]"></div>
        <a href="/projects" class="font-mono text-[9px] text-[#FE9000] tracking-[0.2em] uppercase hover:underline shrink-0">All →</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[#6D5959]">
        {allProjects.map(project => {
          const isActive = project.data.status === 'active';
          return (
            <a
              href={project.data.link ?? '/projects'}
              target={project.data.link ? '_blank' : '_self'}
              rel="noopener noreferrer"
              class={`group block border-[#6D5959] p-8 hover:border-[#FE9000] border transition-colors -m-px${!isActive ? ' opacity-60 hover:opacity-100' : ''}`}
            >
              <div class="flex items-start justify-between gap-4 mb-5">
                <div class="flex items-center gap-2">
                  <span class={`font-mono text-[9px] tracking-[0.15em] uppercase px-2 py-0.5 border
                    ${projectTypeColors[project.data.type] ?? 'text-[#9FA0C3] border-[#6D5959]'}`}>
                    {project.data.type}
                  </span>
                  {!isActive && (
                    <span class="font-mono text-[9px] tracking-[0.1em] uppercase text-[#6D5959]">
                      {project.data.status}
                    </span>
                  )}
                </div>
                {project.data.year && (
                  <span class="font-mono text-[10px] text-[#6D5959]">{project.data.year}</span>
                )}
              </div>
              <h3 class="font-display text-[1.4rem] font-semibold text-[#D2E59E] group-hover:text-[#FE9000] transition-colors leading-tight mb-3">
                {project.data.title}
                {project.data.link && <span class="text-[#6D5959] ml-1">↗</span>}
              </h3>
              <p class="font-serif text-sm text-[#9FA0C3] leading-relaxed">{project.data.description}</p>
            </a>
          );
        })}
      </div>
    </section>
  )}


<script id="network-nodes-data" type="application/json" set:html={JSON.stringify(network_nodes)}></script>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;

    const C = { dim: '#6D5959', mid: '#9FA0C3', accent: '#D2E59E', hot: '#FE9000' };

    const dataEl = document.getElementById('network-nodes-data');
    const BIO: string[] = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];

    type Node = {
      x: number; y: number; vx: number; vy: number;
      r: number; baseR: number; color: string;
      label: string | null; active: boolean; labelOpacity: number; phase: number;
    };

    let W = 0, H = 0, nodes: Node[] = [];
    let mouseX = -9999, mouseY = -9999;

    const MAX_DIST   = 150;
    const HOVER_DIST = 90;

    function rgb(hex: string) {
      return `${parseInt(hex.slice(1,3),16)},${parseInt(hex.slice(3,5),16)},${parseInt(hex.slice(5,7),16)}`;
    }
    const dimRgb = rgb(C.dim);
    const hotRgb = rgb(C.hot);

    function resize() {
      const rect = canvas!.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas!.width  = Math.round(W * devicePixelRatio);
      canvas!.height = Math.round(H * devicePixelRatio);
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
      init();
    }

    function init() {
      const colorPool = [C.dim, C.dim, C.dim, C.mid, C.mid, C.accent];
      const count = Math.max(90, Math.round((W * H) / 5000));
      nodes = Array.from({ length: count }, (_, i) => {
        const isBio   = i < BIO.length;
        const speed   = isBio ? 0.08 + Math.random() * 0.15 : 0.14 + Math.random() * 0.28;
        const angle   = Math.random() * Math.PI * 2;
        const baseR   = isBio ? 10 : 1.2 + Math.random() * 1.8;
        return {
          x: Math.random() * W, y: Math.random() * H,
          vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
          r: baseR, baseR,
          color: isBio ? C.accent : colorPool[Math.floor(Math.random() * colorPool.length)],
          label: isBio ? BIO[i] : null,
          active: false, labelOpacity: 0,
          phase: Math.random() * Math.PI * 2,
        };
      });
    }

    function drawLabel(n: Node) {
      if (!n.label || n.labelOpacity <= 0.01) return;
      const toRight = n.x < W * 0.68;
      const lineLen = 18;
      const gap     = n.r + 10;
      const lx0     = toRight ? n.x + gap : n.x - gap;
      const lx1     = toRight ? lx0 + lineLen : lx0 - lineLen;

      ctx.globalAlpha = n.labelOpacity;
      ctx.strokeStyle = C.hot;
      ctx.lineWidth   = 0.8;
      ctx.beginPath();
      ctx.moveTo(lx0, n.y);
      ctx.lineTo(lx1, n.y);
      ctx.stroke();

      ctx.fillStyle    = C.hot;
      ctx.font         = '9px ui-monospace, Menlo, monospace';
      ctx.textBaseline = 'middle';
      ctx.textAlign    = toRight ? 'left' : 'right';
      ctx.fillText(n.label.toUpperCase(), toRight ? lx1 + 4 : lx1 - 4, n.y);
      ctx.globalAlpha = 1;
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);

      for (const n of nodes) {
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0)  { n.x = 0;  n.vx *= -1; }
        if (n.x > W)  { n.x = W;  n.vx *= -1; }
        if (n.y < 0)  { n.y = 0;  n.vy *= -1; }
        if (n.y > H)  { n.y = H;  n.vy *= -1; }

        if (n.label) {
          const dx = n.x - mouseX, dy = n.y - mouseY;
          n.active = (dx*dx + dy*dy) < HOVER_DIST * HOVER_DIST;
          n.labelOpacity += ((n.active ? 1 : 0) - n.labelOpacity) * 0.09;
          n.r += ((n.active ? n.baseR * 1.55 : n.baseR) - n.r) * 0.12;
        }
      }

      // Edges
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const d2 = dx*dx + dy*dy;
          if (d2 < MAX_DIST * MAX_DIST) {
            const t = 1 - Math.sqrt(d2) / MAX_DIST;
            const anyActive = nodes[i].active || nodes[j].active;
            ctx.strokeStyle = anyActive
              ? `rgba(${hotRgb},${t * 0.65})`
              : `rgba(${dimRgb},${t * 0.42})`;
            ctx.lineWidth = anyActive ? 1 : 0.65;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
      }

      // Pulsing halos for bio nodes
      const t = Date.now() / 1000;
      for (const n of nodes) {
        if (!n.label) continue;
        const pulse = 0.5 + 0.5 * Math.sin(t * 1.4 + n.phase);
        const haloR = n.r * (2.0 + pulse * 0.6);
        const haloAlpha = n.active ? 0 : 0.18 + pulse * 0.14;
        ctx.strokeStyle = `rgba(${rgb(C.accent)},${haloAlpha})`;
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.arc(n.x, n.y, haloR, 0, Math.PI * 2);
        ctx.stroke();
      }

      // Nodes
      for (const n of nodes) {
        ctx.fillStyle  = n.label && n.active ? C.hot : n.color;
        ctx.globalAlpha = n.label ? 0.95 : 0.70;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;

      // Labels on top
      for (const n of nodes) drawLabel(n);

      requestAnimationFrame(draw);
    }

    canvas.addEventListener('mousemove', e => {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; });

    window.addEventListener('resize', () => { ctx.setTransform(1,0,0,1,0,0); resize(); });
    resize();
    draw();
  }
</script>

</BaseLayout>
