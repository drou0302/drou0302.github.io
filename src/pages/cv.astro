---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="CV" description="Curriculum Vitae — David Rourap">
  <div class="max-w-4xl mx-auto px-8 pt-28 pb-20">

    <div class="flex items-center justify-between mb-16">
      <div class="flex items-center gap-5 flex-1">
        <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase">Curriculum Vitae</span>
        <div class="flex-1 h-px bg-[#ddd8ce]"></div>
      </div>
      <a href="/cv.pdf" download
         class="ml-6 font-mono text-[10px] tracking-[0.15em] uppercase text-[#0f0e0c] border border-[#0f0e0c] px-4 py-2 hover:bg-[#0f0e0c] hover:text-[#f4efe5] transition-all shrink-0">
        ↓ PDF
      </a>
    </div>

    <h1 class="font-display text-[clamp(3rem,7vw,5.5rem)] font-semibold leading-[0.9] tracking-[-0.02em] text-[#0f0e0c] mb-16">
      David<br/>Rourap
    </h1>

    <div class="space-y-14">

      <!-- Current -->
      <section>
        <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase block mb-5">Current position</span>
        <div class="border-t border-[#ddd8ce] pt-5">
          <div class="flex justify-between items-start">
            <div>
              <p class="font-serif font-semibold text-[#0f0e0c] text-lg">CEO & Co-founder</p>
              <p class="font-serif text-[#7a7570]">
                <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer"
                   class="hover:text-[#2355b0] transition-colors">inseit.ch</a> · Switzerland
              </p>
            </div>
            <span class="font-mono text-[11px] text-[#aaa59f] shrink-0 ml-8">20XX – present</span>
          </div>
        </div>
      </section>

      <!-- Education -->
      <section>
        <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase block mb-5">Education</span>
        <div class="border-t border-[#ddd8ce] pt-5 space-y-6">
          <div class="flex justify-between items-start">
            <div>
              <p class="font-serif font-semibold text-[#0f0e0c]">[Degree] in [Field]</p>
              <p class="font-serif text-sm text-[#7a7570]">[University] · [Location]</p>
            </div>
            <span class="font-mono text-[11px] text-[#aaa59f] shrink-0 ml-8">20XX – 20XX</span>
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section>
        <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase block mb-5">Experience</span>
        <div class="border-t border-[#ddd8ce] pt-5 space-y-6">
          <div class="flex justify-between items-start">
            <div>
              <p class="font-serif font-semibold text-[#0f0e0c]">[Role]</p>
              <p class="font-serif text-sm text-[#7a7570]">[Institution] · [Location]</p>
              <p class="font-serif text-sm text-[#5a5550] mt-1 max-w-lg">[Brief description of what you did.]</p>
            </div>
            <span class="font-mono text-[11px] text-[#aaa59f] shrink-0 ml-8">20XX – 20XX</span>
          </div>
        </div>
      </section>

      <!-- Publications -->
      <section>
        <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase block mb-5">Publications</span>
        <div class="border-t border-[#ddd8ce] pt-5 space-y-3">
          <p class="font-serif text-sm text-[#5a5550] leading-relaxed">
            [Author(s)]. &ldquo;[Title].&rdquo; <em>[Journal]</em>, [Year].
            <a href="#" class="text-[#2355b0] hover:underline ml-1">DOI ↗</a>
          </p>
        </div>
      </section>

      <!-- Skills -->
      <section>
        <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase block mb-5">Skills</span>
        <div class="border-t border-[#ddd8ce] pt-5 flex flex-wrap gap-2">
          {['[Skill 1]', '[Skill 2]', '[Skill 3]'].map(skill => (
            <span class="font-mono text-[11px] tracking-[0.05em] bg-[#eeeae0] text-[#5a5550] px-3 py-1.5 border border-[#ddd8ce]">
              {skill}
            </span>
          ))}
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
