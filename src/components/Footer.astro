---
const year = new Date().getFullYear();
---
<footer class="border-t border-[#ddd8ce] bg-[#f4efe5] py-10 mt-20">
  <div class="max-w-6xl mx-auto px-8 flex items-center justify-between">
    <span class="font-mono text-[11px] text-[#aaa59f] tracking-[0.12em] uppercase">
      © {year} David Rourap
    </span>
    <div class="flex gap-6">
      <a href="https://github.com/drou0302" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] text-[#aaa59f] hover:text-[#0f0e0c] tracking-[0.12em] uppercase transition-colors">GitHub</a>
      <a href="https://www.linkedin.com/in/davidrourap" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] text-[#aaa59f] hover:text-[#0f0e0c] tracking-[0.12em] uppercase transition-colors">LinkedIn</a>
      <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] text-[#aaa59f] hover:text-[#0f0e0c] tracking-[0.12em] uppercase transition-colors">inseit.ch</a>
    </div>
  </div>
</footer>
