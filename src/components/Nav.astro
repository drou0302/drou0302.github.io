---
const pathname = Astro.url.pathname;
const links = [
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/cv', label: 'CV' },
];
---
<header class="border-b border-stone-200 bg-stone-50/90 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="font-semibold text-stone-900 hover:text-blue-600 transition-colors text-sm tracking-tight">
      David Rourap
    </a>
    <div class="flex items-center gap-5">
      {links.map(link => (
        <a
          href={link.href}
          class={`text-sm transition-colors ${pathname.startsWith(link.href) ? 'text-blue-600 font-medium' : 'text-stone-500 hover:text-stone-900'}`}
        >
          {link.label}
        </a>
      ))}
      <span class="text-stone-200">|</span>
      <a href="https://github.com/drou0302" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-stone-900 transition-colors text-sm">GH</a>
      <a href="https://www.linkedin.com/in/davidrourap" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-stone-900 transition-colors text-sm">LI</a>
    </div>
  </nav>
</header>
